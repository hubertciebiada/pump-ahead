{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=localhost,1433;Initial Catalog=PumpAhead;User ID=sa;Password=Pass12345!;TrustServerCertificate=True"
  },
  "Devices": {
    "Heishamon": {
      "Address": "http://heishamon.local"
    }
  },
  "Polling": {
    "ControlIntervalMinutes": 30
  },
  "Web": {
    "DefaultSensorId": "shellyhtg3-b08184ee93a8",
    "ForecastOffsetHours": 6,
    "TargetIndoorTemperature": 22.0
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/pumpahead-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:1488"
      }
    }
  }
}
