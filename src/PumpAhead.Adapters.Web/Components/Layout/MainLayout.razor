@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Dark">
        <MudLink Href="/" Underline="Underline.None" Color="Color.Inherit">
            <MudText Typo="Typo.h5">PumpAhead</MudText>
        </MudLink>
        <MudLink Href="/" Underline="Underline.None" Color="Color.Inherit" Class="ml-6">
            <MudText Typo="Typo.body1">Dashboard</MudText>
        </MudLink>
        <MudLink Href="/heating-curve" Underline="Underline.None" Color="Color.Inherit" Class="ml-4">
            <MudText Typo="Typo.body1">Krzywa grzewcza</MudText>
        </MudLink>
        <MudSpacer />
        <MudTooltip Text="Odśwież dane">
            <MudIconButton Icon="@Icons.Material.Filled.Refresh" Color="Color.Inherit" />
        </MudTooltip>
        <MudTooltip Text="Ustawienia">
            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" />
        </MudTooltip>
    </MudAppBar>

    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
