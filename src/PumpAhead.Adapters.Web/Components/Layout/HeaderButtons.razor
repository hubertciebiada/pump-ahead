@using Microsoft.Extensions.Options
@using PumpAhead.Adapters.Web.Services
@inject RefreshService RefreshService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IOptions<WebOptions> WebOptions
@rendermode InteractiveServer

<RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
              title="Odswiez dane" Click="@OnRefreshClick" IsBusy="@_isRefreshing" />
<RadzenButton Icon="settings" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
              title="Ustawienia" Click="@OnSettingsClick" />

@code {
    private bool _isRefreshing;

    private async Task OnRefreshClick()
    {
        _isRefreshing = true;
        StateHasChanged();

        try
        {
            await RefreshService.RequestRefreshAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Odswiezono", "Dane zostaly zaktualizowane");
        }
        finally
        {
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    private async Task OnSettingsClick()
    {
        var options = WebOptions.Value;

        var result = await DialogService.OpenAsync<SettingsDialog>(
            "Ustawienia",
            new Dictionary<string, object>
            {
                { nameof(SettingsDialog.TargetIndoorTemperature), options.TargetIndoorTemperature },
                { nameof(SettingsDialog.ForecastOffsetHours), options.ForecastOffsetHours },
                { nameof(SettingsDialog.DefaultSensorId), options.DefaultSensorId }
            },
            new DialogOptions
            {
                Width = "400px",
                CloseDialogOnOverlayClick = true,
                ShowClose = true
            });

        if (result is SettingsDialog.SettingsResult settings)
        {
            options.TargetIndoorTemperature = settings.TargetIndoorTemperature;
            options.ForecastOffsetHours = settings.ForecastOffsetHours;
            options.DefaultSensorId = settings.DefaultSensorId;

            await RefreshService.RequestRefreshAsync();
        }
    }
}
