<div class="reading-entry d-flex align-center py-2">
    <MudIcon Icon="@Icon"
             Size="Size.Small"
             Color="@(IsPlaceholder ? Color.Default : IconColor)"
             Class="mr-3" />
    <MudText Typo="Typo.body2"
             Class="flex-grow-1"
             Style="@(IsPlaceholder ? "opacity: 0.5;" : "")">
        @Label
    </MudText>
    <MudText Typo="Typo.body2"
             Color="@(IsPlaceholder ? Color.Default : Color.Primary)"
             Style="@(IsPlaceholder ? "opacity: 0.5; font-style: italic;" : "font-weight: 500;")">
        @Value
    </MudText>
</div>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Info;
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "--";
    [Parameter] public Color IconColor { get; set; } = Color.Primary;
    [Parameter] public bool IsPlaceholder { get; set; } = false;
}
