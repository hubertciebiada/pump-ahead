<div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0; @(string.IsNullOrEmpty(Tooltip) ? "" : "cursor: help;")"
     title="@Tooltip">
    <RadzenIcon Icon="@Icon" Style="@GetIconStyleWithShrink()" />
    <span style="@GetLabelStyle()">@Label</span>
    <span style="@GetValueStyle()">@Value</span>
</div>

@code {
    [Parameter] public string Icon { get; set; } = "info";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "--";
    [Parameter] public string IconColor { get; set; } = "primary";
    [Parameter] public bool IsPlaceholder { get; set; } = false;
    [Parameter] public string Tooltip { get; set; } = "";

    private string GetIconStyleWithShrink()
    {
        var color = IsPlaceholder ? "var(--rz-text-disabled-color)" : GetColorValue(IconColor);
        return $"color: {color}; font-size: 1.25rem; flex-shrink: 0;";
    }

    private string GetLabelStyle()
    {
        var opacity = IsPlaceholder ? "opacity: 0.5;" : "";
        return $"flex: 1; font-size: 0.875rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; {opacity}";
    }

    private string GetValueStyle()
    {
        if (IsPlaceholder)
        {
            return "font-size: 0.875rem; opacity: 0.5; font-style: italic; text-align: right; min-width: 60px;";
        }
        return "font-size: 0.875rem; font-weight: 600; color: var(--rz-primary); text-align: right; min-width: 60px;";
    }

    private string GetColorValue(string colorName) => colorName.ToLower() switch
    {
        "primary" => "var(--rz-primary)",
        "secondary" => "var(--rz-secondary)",
        "success" => "var(--rz-success)",
        "warning" => "var(--rz-warning)",
        "error" => "var(--rz-danger)",
        "info" => "var(--rz-info)",
        _ => "var(--rz-text-color)"
    };
}
