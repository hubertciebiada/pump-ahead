@page "/heating-curve"
@rendermode InteractiveServer

<PageTitle>Krzywa grzewcza - PumpAhead</PageTitle>

<RadzenCard class="rz-p-4">
    <RadzenText TextStyle="TextStyle.H6" class="rz-mb-3">Krzywa grzewcza</RadzenText>
    <RadzenText TextStyle="TextStyle.Body2" class="rz-mb-4" Style="color: var(--rz-text-secondary-color);">
        Zależność temperatury zasilania od temperatury zewnętrznej. Zakres: -15°C (31°C zasilania) do 15°C (24°C zasilania).
    </RadzenText>

    <RadzenChart style="height: 500px; width: 100%;">
        <RadzenLineSeries Data="@_curveData"
                          CategoryProperty="OutdoorTemp"
                          ValueProperty="SupplyTemp"
                          Title="Temp. zasilania"
                          Stroke="var(--rz-primary)"
                          StrokeWidth="3">
            <RadzenMarkers Visible="true" MarkerType="MarkerType.Circle" Size="4" />
        </RadzenLineSeries>

        <RadzenCategoryAxis Min="-20" Max="20" Step="5" FormatString="{0}°C" LabelRotation="-45">
            <RadzenGridLines Visible="true" />
            <RadzenAxisTitle Text="Temperatura zewnętrzna (°C)" />
        </RadzenCategoryAxis>

        <RadzenValueAxis Min="20" Max="35" Step="1">
            <RadzenGridLines Visible="true" />
            <RadzenAxisTitle Text="Temperatura zasilania (°C)" />
        </RadzenValueAxis>

        <RadzenLegend Visible="false" />
        <RadzenChartTooltipOptions Visible="true" />
    </RadzenChart>
</RadzenCard>

@code {
    private List<HeatingCurvePoint> _curveData = new();

    protected override void OnInitialized()
    {
        BuildHeatingCurve();
    }

    private void BuildHeatingCurve()
    {
        // HLD specification: (-15°C outdoor, 31°C supply) and (15°C outdoor, 24°C supply)
        // Extended range: -20 to +20 to show flat regions outside curve
        const double curveMinOutdoor = -15.0;
        const double curveMaxOutdoor = 15.0;
        const double supplyAtMinOutdoor = 31.0;
        const double supplyAtMaxOutdoor = 24.0;

        // Extended display range (+/- 5°C beyond curve endpoints)
        const double displayMin = -20.0;
        const double displayMax = 20.0;

        // Generate points every 5°C for cleaner chart
        for (double outdoor = displayMin; outdoor <= displayMax; outdoor += 5.0)
        {
            double supply;
            if (outdoor <= curveMinOutdoor)
            {
                // Below curve range - flat at max supply temp
                supply = supplyAtMinOutdoor;
            }
            else if (outdoor >= curveMaxOutdoor)
            {
                // Above curve range - flat at min supply temp
                supply = supplyAtMaxOutdoor;
            }
            else
            {
                // Within curve range - linear interpolation
                supply = supplyAtMinOutdoor - ((outdoor - curveMinOutdoor) * (supplyAtMinOutdoor - supplyAtMaxOutdoor) / (curveMaxOutdoor - curveMinOutdoor));
            }

            _curveData.Add(new HeatingCurvePoint
            {
                OutdoorTemp = outdoor,
                SupplyTemp = Math.Round(supply, 1)
            });
        }
    }

    private class HeatingCurvePoint
    {
        public double OutdoorTemp { get; set; }
        public double SupplyTemp { get; set; }
    }
}
