@page "/"
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using PumpAhead.DeepModel.ValueObjects
@using PumpAhead.UseCases.Ports
@using PumpAhead.UseCases.Queries.GetTemperature
@using PumpAhead.UseCases.Queries.GetTemperatureHistory
@using PumpAhead.Adapters.Web.Services
@inject IServiceScopeFactory ScopeFactory
@inject IOptions<WebOptions> WebOptions
@inject RefreshService RefreshService
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Dashboard - PumpAhead</PageTitle>

@* Chart - full width at top *@
<RadzenCard class="rz-p-3 rz-mb-4">
    @if (_chartData.Any())
    {
        <RadzenChart style="height: 400px; width: 100%;">
            <RadzenLineSeries Data="@_chartData.Where(d => d.IsHistorical)"
                              CategoryProperty="TimeLabel"
                              ValueProperty="Temperature"
                              Title="Temperatura"
                              Stroke="var(--rz-primary)"
                              StrokeWidth="2">
                <RadzenMarkers Visible="false" />
            </RadzenLineSeries>

            <RadzenLineSeries Data="@_chartData.Where(d => d.IsForecast)"
                              CategoryProperty="TimeLabel"
                              ValueProperty="Temperature"
                              Title="Prognoza"
                              Stroke="var(--rz-warning)"
                              StrokeWidth="2"
                              LineType="LineType.Dashed">
                <RadzenMarkers Visible="false" />
            </RadzenLineSeries>

            <RadzenCategoryAxis Padding="20" LabelRotation="-45">
                <RadzenAxisTitle Text="Czas" />
            </RadzenCategoryAxis>

            <RadzenValueAxis Min="-20" Max="40" Step="10">
                <RadzenGridLines Visible="true" />
                <RadzenAxisTitle Text="Temperatura (°C)" />
            </RadzenValueAxis>

            <RadzenLegend Visible="true" Position="LegendPosition.Top" />
            <RadzenChartTooltipOptions Visible="true" />
        </RadzenChart>
    }
    else
    {
        <div style="display: flex; align-items: center; gap: 1rem;">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            <RadzenText TextStyle="TextStyle.Body2">Ładowanie danych...</RadzenText>
        </div>
    }
</RadzenCard>

@* Data sections - horizontal layout below chart *@
<RadzenRow Gap="1rem">
    @* OTOCZENIE *@
    <RadzenColumn Size="12" SizeSM="6" SizeMD="4" SizeLG="2">
        <RadzenCard class="rz-p-3" style="height: 100%;">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3" Style="font-weight: 600;">Otoczenie</RadzenText>

            <ReadingEntry Icon="home"
                          Label="Wewnętrzna (aktualna)"
                          Value="@_indoorTempDisplay"
                          IconColor="primary"
                          IsPlaceholder="@(_currentTemperature is null)"
                          Tooltip="Aktualna temperatura w pomieszczeniu zmierzona przez czujnik Shelly" />

            <ReadingEntry Icon="thermostat"
                          Label="Wewnętrzna (oczekiwana)"
                          Value="@($"{WebOptions.Value.TargetIndoorTemperature:F1}°C")"
                          IconColor="success"
                          IsPlaceholder="false"
                          Tooltip="Docelowa temperatura wewnętrzna ustawiona przez użytkownika" />

            <ReadingEntry Icon="cloud"
                          Label="Zewnętrzna (aktualna)"
                          Value="--"
                          IconColor="info"
                          IsPlaceholder="true"
                          Tooltip="Aktualna temperatura zewnętrzna odczytana z pompy ciepła" />
        </RadzenCard>
    </RadzenColumn>

    @* PROGNOZA *@
    <RadzenColumn Size="12" SizeSM="6" SizeMD="4" SizeLG="2">
        <RadzenCard class="rz-p-3" style="height: 100%;">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3" Style="font-weight: 600;">Prognoza</RadzenText>

            <ReadingEntry Icon="schedule"
                          Label="@($"Zewnętrzna (+{WebOptions.Value.ForecastOffsetHours}h)")"
                          Value="--"
                          IconColor="warning"
                          IsPlaceholder="true"
                          Tooltip="@($"Prognozowana temperatura zewnętrzna za {WebOptions.Value.ForecastOffsetHours} godzin")" />

            <ReadingEntry Icon="trending_up"
                          Label="Korekta empiryczna"
                          Value="--"
                          IconColor="secondary"
                          IsPlaceholder="true"
                          Tooltip="Korekta prognozy na podstawie różnicy między prognozami a rzeczywistością" />
        </RadzenCard>
    </RadzenColumn>

    @* CO (Centralne Ogrzewanie) *@
    <RadzenColumn Size="12" SizeSM="6" SizeMD="4" SizeLG="2">
        <RadzenCard class="rz-p-3" style="height: 100%;">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3" Style="font-weight: 600;">CO</RadzenText>

            <ReadingEntry Icon="show_chart"
                          Label="Zasilanie wg krzywej"
                          Value="--"
                          IconColor="default"
                          IsPlaceholder="true"
                          Tooltip="Temperatura zasilania z oryginalnej krzywej grzewczej" />

            <ReadingEntry Icon="timer"
                          Label="Offset"
                          Value="@($"{WebOptions.Value.ForecastOffsetHours}h")"
                          IconColor="info"
                          IsPlaceholder="false"
                          Tooltip="Przesunięcie czasowe uwzględniające bezwładność termiczną" />

            <ReadingEntry Icon="calculate"
                          Label="Zasilanie z offsetem"
                          Value="--"
                          IconColor="primary"
                          IsPlaceholder="true"
                          Tooltip="Temperatura zasilania z uwzględnieniem offsetu i prognozy" />

            <ReadingEntry Icon="tune"
                          Label="Zasilanie zadane"
                          Value="--"
                          IconColor="warning"
                          IsPlaceholder="true"
                          Tooltip="Temperatura zasilania wysłana do pompy ciepła" />

            <ReadingEntry Icon="opacity"
                          Label="Zasilanie faktyczne"
                          Value="--"
                          IconColor="error"
                          IsPlaceholder="true"
                          Tooltip="Rzeczywista temperatura wody zasilającej" />

            <ReadingEntry Icon="water_drop"
                          Label="Powrót faktyczny"
                          Value="--"
                          IconColor="secondary"
                          IsPlaceholder="true"
                          Tooltip="Rzeczywista temperatura wody powrotnej" />
        </RadzenCard>
    </RadzenColumn>

    @* CWU (Ciepła Woda Użytkowa) *@
    <RadzenColumn Size="12" SizeSM="6" SizeMD="4" SizeLG="3">
        <RadzenCard class="rz-p-3" style="height: 100%;">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3" Style="font-weight: 600;">CWU</RadzenText>

            <ReadingEntry Icon="bathtub"
                          Label="Zadana"
                          Value="--"
                          IconColor="warning"
                          IsPlaceholder="true"
                          Tooltip="Docelowa temperatura ciepłej wody użytkowej" />

            <ReadingEntry Icon="hot_tub"
                          Label="Aktualna"
                          Value="--"
                          IconColor="error"
                          IsPlaceholder="true"
                          Tooltip="Aktualna temperatura wody w zasobniku CWU" />

            <ReadingEntry Icon="swap_vert"
                          Label="Delta wygrzewania"
                          Value="--"
                          IconColor="info"
                          IsPlaceholder="true"
                          Tooltip="Różnica temperatur uruchamiająca wygrzewanie CWU" />

            <ReadingEntry Icon="wb_sunny"
                          Label="Sugerowana godz. wygrzewania"
                          Value="--"
                          IconColor="success"
                          IsPlaceholder="true"
                          Tooltip="Optymalna godzina wygrzewania CWU dla najwyższego COP" />
        </RadzenCard>
    </RadzenColumn>

    @* SPRĘŻARKA *@
    <RadzenColumn Size="12" SizeSM="6" SizeMD="4" SizeLG="3">
        <RadzenCard class="rz-p-3" style="height: 100%;">
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-mb-3" Style="font-weight: 600;">Sprężarka</RadzenText>

            <ReadingEntry Icon="speed"
                          Label="Częstotliwość"
                          Value="--"
                          IconColor="primary"
                          IsPlaceholder="true"
                          Tooltip="Aktualna częstotliwość pracy sprężarki w Hz" />

            <ReadingEntry Icon="replay"
                          Label="Cykle włącz/wyłącz"
                          Value="--"
                          IconColor="warning"
                          IsPlaceholder="true"
                          Tooltip="Liczba cykli włączenia i wyłączenia sprężarki" />

            <ReadingEntry Icon="access_time"
                          Label="Czas pracy"
                          Value="--"
                          IconColor="info"
                          IsPlaceholder="true"
                          Tooltip="Całkowity czas pracy sprężarki" />
        </RadzenCard>
    </RadzenColumn>
</RadzenRow>

@code {
    private GetTemperature.Data? _currentTemperature;
    private string _indoorTempDisplay = "--";
    private List<ChartDataPoint> _chartData = new();

    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        RefreshService.OnRefreshRequested += OnRefreshRequested;
        await LoadDataAsync();

        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
    }

    private async Task OnRefreshRequested()
    {
        await LoadDataAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDataAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var getTemperatureHandler = scope.ServiceProvider
            .GetRequiredService<IQueryHandler<GetTemperature.Query, GetTemperature.Data?>>();
        var getTemperatureHistoryHandler = scope.ServiceProvider
            .GetRequiredService<IQueryHandler<GetTemperatureHistory.Query, GetTemperatureHistory.Data>>();

        var sensorId = SensorId.From(WebOptions.Value.DefaultSensorId);

        _currentTemperature = await getTemperatureHandler.HandleAsync(new GetTemperature.Query(sensorId));
        _indoorTempDisplay = _currentTemperature?.Temperature.ToString() ?? "--";

        var now = DateTimeOffset.UtcNow;
        var historyData = await getTemperatureHistoryHandler.HandleAsync(
            new GetTemperatureHistory.Query(sensorId, now.AddHours(-24), now));

        BuildChart(historyData.Readings);
    }

    private void BuildChart(IReadOnlyList<GetTemperatureHistory.DataPoint> readings)
    {
        // Create fixed time axis: -24h to +12h with 12-hour intervals (4 points for mobile)
        var now = DateTimeOffset.Now;
        var currentHour = new DateTimeOffset(now.Year, now.Month, now.Day, now.Hour, 0, 0, now.Offset);

        // Round to nearest 12-hour mark (00:00 or 12:00)
        var roundedHour = (currentHour.Hour / 12) * 12;
        var baseTime = new DateTimeOffset(now.Year, now.Month, now.Day, roundedHour, 0, 0, now.Offset);

        var startTime = baseTime.AddHours(-24);
        var endTime = baseTime.AddHours(12);

        // Build 12-hour slots for the axis (4 points)
        var timeSlots = new List<DateTimeOffset>();
        for (var t = startTime; t <= endTime; t = t.AddHours(12))
        {
            timeSlots.Add(t);
        }

        // Map readings to nearest 12-hour slot
        var readingsBySlot = readings
            .GroupBy(r =>
            {
                var localTime = r.Timestamp.ToLocalTime();
                var slotHour = (localTime.Hour / 12) * 12;
                return new DateTimeOffset(localTime.Year, localTime.Month, localTime.Day, slotHour, 0, 0, now.Offset);
            })
            .ToDictionary(g => g.Key, g => g.Average(r => (double)r.Temperature.Celsius));

        _chartData = new List<ChartDataPoint>();
        double lastKnownValue = 20.0; // Default temperature

        foreach (var slot in timeSlots)
        {
            var isHistorical = slot <= currentHour;

            if (isHistorical && readingsBySlot.TryGetValue(slot, out var temp))
            {
                lastKnownValue = temp;
            }

            // Format: "23.01 12:00" for clear day identification
            _chartData.Add(new ChartDataPoint
            {
                Time = slot,
                TimeLabel = slot.ToString("dd.MM HH:mm"),
                Temperature = Math.Round(lastKnownValue, 1),
                IsHistorical = isHistorical,
                IsForecast = !isHistorical
            });
        }
    }

    public void Dispose()
    {
        RefreshService.OnRefreshRequested -= OnRefreshRequested;
        _refreshTimer?.Dispose();
    }

    private class ChartDataPoint
    {
        public DateTimeOffset Time { get; set; }
        public string TimeLabel { get; set; } = "";
        public double Temperature { get; set; }
        public bool IsHistorical { get; set; }
        public bool IsForecast { get; set; }
    }
}
