@page "/"
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@using PumpAhead.DeepModel.ValueObjects
@using PumpAhead.UseCases.Ports
@using PumpAhead.UseCases.Queries.GetTemperature
@using PumpAhead.UseCases.Queries.GetTemperatureHistory
@inject IServiceScopeFactory ScopeFactory
@inject IOptions<WebOptions> WebOptions
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Dashboard - PumpAhead</PageTitle>

<MudGrid>
    @* Left side - Chart (75% width) *@
    <MudItem xs="12" md="9">
        <MudPaper Class="pa-3" Elevation="2">
            @if (_chartSeries.Any())
            {
                <MudChart ChartType="ChartType.Line"
                          ChartSeries="@_chartSeries"
                          XAxisLabels="@_chartLabels"
                          Width="100%"
                          Height="500px"
                          ChartOptions="@_chartOptions"
                          LegendPosition="Position.Right" />
            }
            else
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mt-2">Ładowanie danych...</MudText>
            }
        </MudPaper>
    </MudItem>

    @* Right side - Current readings (25% width) *@
    <MudItem xs="12" md="3">
        <MudPaper Class="pa-3" Elevation="2">

            @* ==================== OTOCZENIE ==================== *@
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Otoczenie</MudText>

            <ReadingEntry Icon="@Icons.Material.Filled.Home"
                          Label="Wewnętrzna (aktualna)"
                          Value="@_indoorTempDisplay"
                          IconColor="Color.Primary"
                          IsPlaceholder="@(_currentTemperature is null)"
                          Tooltip="Aktualna temperatura w pomieszczeniu zmierzona przez czujnik Shelly" />

            <ReadingEntry Icon="@Icons.Material.Filled.Thermostat"
                          Label="Wewnętrzna (oczekiwana)"
                          Value="@($"{WebOptions.Value.TargetIndoorTemperature:F1}°C")"
                          IconColor="Color.Success"
                          IsPlaceholder="false"
                          Tooltip="Docelowa temperatura wewnętrzna ustawiona przez użytkownika" />

            <ReadingEntry Icon="@Icons.Material.Filled.Cloud"
                          Label="Zewnętrzna (aktualna)"
                          Value="--"
                          IconColor="Color.Info"
                          IsPlaceholder="true"
                          Tooltip="Aktualna temperatura zewnętrzna odczytana z pompy ciepła" />

            <MudDivider Class="my-2" />

            @* ==================== PROGNOZA ==================== *@
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Prognoza</MudText>

            <ReadingEntry Icon="@Icons.Material.Filled.Schedule"
                          Label="@($"Zewnętrzna (+{WebOptions.Value.ForecastOffsetHours}h)")"
                          Value="--"
                          IconColor="Color.Warning"
                          IsPlaceholder="true"
                          Tooltip="@($"Prognozowana temperatura zewnętrzna za {WebOptions.Value.ForecastOffsetHours} godzin (offset uwzględniający bezwładność termiczną budynku)")" />

            <ReadingEntry Icon="@Icons.Material.Filled.TrendingUp"
                          Label="Korekta empiryczna"
                          Value="--"
                          IconColor="Color.Tertiary"
                          IsPlaceholder="true"
                          Tooltip="Korekta prognozy obliczona na podstawie różnicy między poprzednimi prognozami a rzeczywistością" />

            <MudDivider Class="my-2" />

            @* ==================== CO (Centralne Ogrzewanie) ==================== *@
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">CO</MudText>

            <ReadingEntry Icon="@Icons.Material.Filled.ShowChart"
                          Label="Zasilanie wg krzywej"
                          Value="--"
                          IconColor="Color.Default"
                          IsPlaceholder="true"
                          Tooltip="Temperatura zasilania wyliczona z oryginalnej krzywej grzewczej (bez offsetu)" />

            <ReadingEntry Icon="@Icons.Material.Filled.Timer"
                          Label="Offset"
                          Value="@($"{WebOptions.Value.ForecastOffsetHours}h")"
                          IconColor="Color.Info"
                          IsPlaceholder="false"
                          Tooltip="Przesunięcie czasowe uwzględniające bezwładność termiczną instalacji grzewczej" />

            <ReadingEntry Icon="@Icons.Material.Filled.Calculate"
                          Label="Zasilanie z offsetem"
                          Value="--"
                          IconColor="Color.Primary"
                          IsPlaceholder="true"
                          Tooltip="Temperatura zasilania wyliczona z krzywej grzewczej z uwzględnieniem offsetu i prognozy pogody" />

            <ReadingEntry Icon="@Icons.Material.Filled.Tune"
                          Label="Zasilanie zadane"
                          Value="--"
                          IconColor="Color.Warning"
                          IsPlaceholder="true"
                          Tooltip="Temperatura zasilania aktualnie wysłana do pompy ciepła" />

            <ReadingEntry Icon="@Icons.Material.Filled.Opacity"
                          Label="Zasilanie faktyczne"
                          Value="--"
                          IconColor="Color.Error"
                          IsPlaceholder="true"
                          Tooltip="Rzeczywista temperatura wody zasilającej zmierzona przez pompę ciepła" />

            <ReadingEntry Icon="@Icons.Material.Filled.WaterDrop"
                          Label="Powrót faktyczny"
                          Value="--"
                          IconColor="Color.Secondary"
                          IsPlaceholder="true"
                          Tooltip="Rzeczywista temperatura wody powrotnej zmierzona przez pompę ciepła" />

            <MudDivider Class="my-2" />

            @* ==================== CWU (Ciepła Woda Użytkowa) ==================== *@
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">CWU</MudText>

            <ReadingEntry Icon="@Icons.Material.Filled.Bathtub"
                          Label="Zadana"
                          Value="--"
                          IconColor="Color.Warning"
                          IsPlaceholder="true"
                          Tooltip="Docelowa temperatura ciepłej wody użytkowej ustawiona w pompie ciepła" />

            <ReadingEntry Icon="@Icons.Material.Filled.HotTub"
                          Label="Aktualna"
                          Value="--"
                          IconColor="Color.Error"
                          IsPlaceholder="true"
                          Tooltip="Aktualna temperatura wody w zasobniku CWU" />

            <ReadingEntry Icon="@Icons.Material.Filled.SwapVert"
                          Label="Delta uruchomienia wygrzewania"
                          Value="--"
                          IconColor="Color.Info"
                          IsPlaceholder="true"
                          Tooltip="Różnica temperatur poniżej zadanej, przy której uruchamia się wygrzewanie CWU" />

            <ReadingEntry Icon="@Icons.Material.Filled.WbSunny"
                          Label="Sugerowana godzina wygrzewania"
                          Value="--"
                          IconColor="Color.Success"
                          IsPlaceholder="true"
                          Tooltip="Sugerowana godzina wygrzewania CWU na podstawie prognozy pogody - wtedy temperatura zewnętrzna będzie najwyższa, co zapewni najwyższy COP pompy ciepła" />

            <MudDivider Class="my-2" />

            @* ==================== SPRĘŻARKA ==================== *@
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Sprężarka</MudText>

            <ReadingEntry Icon="@Icons.Material.Filled.Speed"
                          Label="Częstotliwość"
                          Value="--"
                          IconColor="Color.Primary"
                          IsPlaceholder="true"
                          Tooltip="Aktualna częstotliwość pracy sprężarki w Hz" />

            <ReadingEntry Icon="@Icons.Material.Filled.Replay"
                          Label="Cykle włącz/wyłącz"
                          Value="--"
                          IconColor="Color.Warning"
                          IsPlaceholder="true"
                          Tooltip="Liczba cykli włączenia i wyłączenia sprężarki" />

            <ReadingEntry Icon="@Icons.Material.Filled.AccessTime"
                          Label="Czas pracy"
                          Value="--"
                          IconColor="Color.Info"
                          IsPlaceholder="true"
                          Tooltip="Całkowity czas pracy sprężarki" />
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private GetTemperature.Data? _currentTemperature;
    private string _indoorTempDisplay = "--";
    private List<ChartSeries> _chartSeries = new();
    private string[] _chartLabels = Array.Empty<string>();
    private ChartOptions _chartOptions = new()
    {
        YAxisTicks = 1,
        MaxNumYAxisTicks = 10,
        LineStrokeWidth = 2
    };

    private System.Threading.Timer? _refreshTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();

        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await LoadDataAsync();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromMinutes(1), TimeSpan.FromMinutes(1));
    }

    private async Task LoadDataAsync()
    {
        await using var scope = ScopeFactory.CreateAsyncScope();
        var getTemperatureHandler = scope.ServiceProvider
            .GetRequiredService<IQueryHandler<GetTemperature.Query, GetTemperature.Data?>>();
        var getTemperatureHistoryHandler = scope.ServiceProvider
            .GetRequiredService<IQueryHandler<GetTemperatureHistory.Query, GetTemperatureHistory.Data>>();

        var sensorId = SensorId.From(WebOptions.Value.DefaultSensorId);

        _currentTemperature = await getTemperatureHandler.HandleAsync(new GetTemperature.Query(sensorId));
        _indoorTempDisplay = _currentTemperature?.Temperature.ToString() ?? "--";

        var now = DateTimeOffset.UtcNow;
        var historyData = await getTemperatureHistoryHandler.HandleAsync(
            new GetTemperatureHistory.Query(sensorId, now.AddHours(-24), now));

        BuildChart(historyData.Readings);
    }

    private void BuildChart(IReadOnlyList<GetTemperatureHistory.DataPoint> readings)
    {
        // Create fixed time axis: current hour -24h to +12h (37 hourly slots)
        var now = DateTimeOffset.Now;
        var currentHour = new DateTimeOffset(now.Year, now.Month, now.Day, now.Hour, 0, 0, now.Offset);
        var startTime = currentHour.AddHours(-24);
        var endTime = currentHour.AddHours(12);

        // Build hourly slots for the axis
        var hourlySlots = new List<DateTimeOffset>();
        for (var t = startTime; t <= endTime; t = t.AddHours(1))
        {
            hourlySlots.Add(t);
        }

        // Find the index where "now" starts (hour 24 = index 24)
        var nowIndex = 24;

        // Map readings to nearest hour slot
        var readingsByHour = readings
            .GroupBy(r =>
            {
                var localTime = r.Timestamp.ToLocalTime();
                return new DateTimeOffset(localTime.Year, localTime.Month, localTime.Day, localTime.Hour, 0, 0, now.Offset);
            })
            .ToDictionary(g => g.Key, g => g.Average(r => (double)r.Temperature.Celsius));

        // Create historical data array (past 24h + current hour, indices 0-24)
        // Use 0 for missing values (MudBlazor doesn't handle NaN well)
        var historicalData = new double[hourlySlots.Count];
        double lastKnownValue = 20.0; // Default temperature

        for (int i = 0; i <= nowIndex && i < hourlySlots.Count; i++)
        {
            if (readingsByHour.TryGetValue(hourlySlots[i], out var temp))
            {
                historicalData[i] = temp;
                lastKnownValue = temp;
            }
            else
            {
                historicalData[i] = lastKnownValue;
            }
        }

        // Future hours: continue with last known value (will be hidden by forecast line)
        for (int i = nowIndex + 1; i < hourlySlots.Count; i++)
        {
            historicalData[i] = 0; // Zero for future (won't show as line continues from last point)
        }

        // Create forecast placeholder array (from current hour onwards)
        var forecastData = new double[hourlySlots.Count];
        for (int i = 0; i < hourlySlots.Count; i++)
        {
            if (i >= nowIndex)
            {
                forecastData[i] = lastKnownValue; // Flat line at last known temperature
            }
            else
            {
                forecastData[i] = 0; // Zero for past (won't affect the line)
            }
        }

        // Show labels every 3 hours
        _chartLabels = hourlySlots
            .Select((slot, i) => i % 3 == 0 ? slot.ToString("HH:mm") : "")
            .ToArray();

        _chartSeries = new List<ChartSeries>
        {
            new ChartSeries
            {
                Name = "Temperatura",
                Data = historicalData
            },
            new ChartSeries
            {
                Name = "Prognoza",
                Data = forecastData
            }
        };
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
