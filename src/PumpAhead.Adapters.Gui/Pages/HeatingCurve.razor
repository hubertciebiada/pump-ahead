@page "/heating-curve"
@implements IAsyncDisposable
@inject LightweightChartsService ChartService
@inject ILogger<HeatingCurve> Logger

<PageTitle>Krzywa grzewcza - PumpAhead</PageTitle>

<div class="dashboard-layout">
    <div class="chart-column">
        <div class="chart-container">
            <div id="chart-curve" class="chart-wrapper">
                @if (!_chartInitialized)
                {
                    <div class="no-data-message">Inicjalizacja wykresu...</div>
                }
            </div>
        </div>
    </div>

    <div class="data-panel">
        <div class="panel-section">
            <div class="section-title">Parametry krzywej</div>
            <div class="panel-row">
                <RadzenIcon Icon="ac_unit" Style="color: var(--color-cyan);" />
                <span class="panel-label">Przy @CurveMinOutdoor°C zewn.</span>
                <span class="panel-value">@SupplyAtMinOutdoor°C zasilania</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="wb_sunny" Style="color: var(--color-orange);" />
                <span class="panel-label">Przy @CurveMaxOutdoor°C zewn.</span>
                <span class="panel-value">@SupplyAtMaxOutdoor°C zasilania</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="arrow_downward" Style="color: var(--color-blue);" />
                <span class="panel-label">Minimum zasilania</span>
                <span class="panel-value">@MinSupplyTemp°C</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="arrow_upward" Style="color: var(--color-red);" />
                <span class="panel-label">Maksimum zasilania</span>
                <span class="panel-value">@MaxSupplyTemp°C</span>
            </div>
        </div>

    </div>
</div>

@code {
    // Curve definition points
    private const int CurveMinOutdoor = -15;
    private const int CurveMaxOutdoor = 15;
    private const decimal SupplyAtMinOutdoor = 32m;
    private const decimal SupplyAtMaxOutdoor = 24m;

    // Supply temp limits (flat regions)
    private const decimal MinSupplyTemp = 20m;
    private const decimal MaxSupplyTemp = 35m;

    // Chart display range (extended to show flat regions where clamping occurs)
    // With slope -7/30 per degree, 35°C is reached at -32°C outdoor, 20°C at +32°C outdoor
    private const int ChartMinOutdoor = -35;
    private const int ChartMaxOutdoor = 35;

    private string? _chartId;
    private string? _seriesId;
    private bool _chartInitialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeChartAsync();
            _chartInitialized = true;
            StateHasChanged();
        }
    }

    private async Task InitializeChartAsync()
    {
        try
        {
            _chartId = await ChartService.InitializeXYChartAsync("chart-curve");
            if (_chartId == null) return;

            _seriesId = await ChartService.AddLineSeriesAsync(
                _chartId,
                new LineSeriesOptions("#ff4081", 3, "Krzywa grzewcza", PriceRangeMin: MinSupplyTemp - 2, PriceRangeMax: MaxSupplyTemp + 2));

            if (_seriesId != null)
            {
                var dataPoints = GenerateHeatingCurveData()
                    .Select(p => new ChartDataPoint(p.OutdoorTemp, p.SupplyTemp))
                    .ToList();

                await ChartService.SetDataAsync(_seriesId, dataPoints);
            }

            await ChartService.SetXYVisibleRangeAsync(_chartId, ChartMinOutdoor, ChartMaxOutdoor);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize heating curve chart");
        }
    }

    private static List<CurvePoint> GenerateHeatingCurveData()
    {
        var points = new List<CurvePoint>();

        for (var outdoorTemp = ChartMinOutdoor; outdoorTemp <= ChartMaxOutdoor; outdoorTemp++)
        {
            var supplyTemp = CalculateSupplyTemperature(outdoorTemp);
            points.Add(new CurvePoint(outdoorTemp, supplyTemp));
        }

        return points;
    }

    private static decimal CalculateSupplyTemperature(int outdoorTemp)
    {
        // Linear interpolation between curve definition points
        var ratio = (outdoorTemp - (decimal)CurveMinOutdoor) / (CurveMaxOutdoor - CurveMinOutdoor);
        var supply = SupplyAtMinOutdoor + ratio * (SupplyAtMaxOutdoor - SupplyAtMinOutdoor);

        // Clamp to min/max supply limits (creates flat regions)
        return Math.Clamp(supply, MinSupplyTemp, MaxSupplyTemp);
    }

    private record CurvePoint(int OutdoorTemp, decimal SupplyTemp);

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_chartId != null)
            {
                await ChartService.DestroyChartAsync(_chartId);
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit already disconnected
        }
    }
}
