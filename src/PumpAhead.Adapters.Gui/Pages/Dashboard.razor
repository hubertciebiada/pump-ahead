@page "/"
@implements IAsyncDisposable
@inject IQueryHandler<GetAllSensorsHistory.Query, GetAllSensorsHistory.Data> SensorHistoryHandler
@inject IQueryHandler<GetWeatherForecast.Query, GetWeatherForecast.Data> WeatherForecastHandler
@inject IQueryHandler<GetTemperature.Query, GetTemperature.Data?> TemperatureHandler
@inject LightweightChartsService ChartService
@inject NavigationManager NavigationManager
@inject ILogger<Dashboard> Logger

<PageTitle>Dashboard - PumpAhead</PageTitle>

<div class="dashboard-layout">
    <div class="charts-column">
        <div class="chart-container">
            <div class="chart-title">Temperatura zewnętrzna</div>
            <div id="chart-outdoor" class="chart-wrapper">
                @if (!_hasOutdoorData)
                {
                    <div class="no-data-message">Brak danych pogodowych</div>
                }
            </div>
        </div>

        <div class="chart-container">
            <div class="chart-title">Centralne Ogrzewanie</div>
            <div id="chart-heating" class="chart-wrapper">
                @if (!_hasHeatingData)
                {
                    <div class="no-data-message">Brak danych (Heishamon - Faza 1)</div>
                }
            </div>
        </div>

        <div class="chart-container">
            <div class="chart-title">Temperatura wewnętrzna</div>
            <div id="chart-indoor" class="chart-wrapper">
                @if (!_hasIndoorData)
                {
                    <div class="no-data-message">Brak danych z sensorów</div>
                }
            </div>
        </div>
    </div>

    <div class="data-panel">
        <div class="panel-section">
            <div class="section-title">Otoczenie</div>
            @foreach (var sensor in _sensorData)
            {
                <div class="panel-row">
                    <RadzenIcon Icon="home" Style="color: var(--color-blue);" />
                    <span class="panel-label">@sensor.DisplayName</span>
                    <span class="panel-value">@FormatLatestTemperature(sensor)</span>
                </div>
            }
            <div class="panel-row">
                <RadzenIcon Icon="thermostat" Style="color: var(--color-green);" />
                <span class="panel-label">Wewn. oczekiwana</span>
                <span class="panel-value">@TargetTemperature.ToString()</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="cloud" Style="color: var(--color-cyan);" />
                <span class="panel-label">Zewn. aktualna</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="schedule" Style="color: var(--color-orange);" />
                <span class="panel-label">Zewn. +6h</span>
                <span class="panel-value">@FormatForecastTemp(6)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="trending_up" Style="color: var(--color-gray);" />
                <span class="panel-label">Korekta emp.</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
        </div>

        <div class="panel-section">
            <div class="section-title">CO</div>
            <div class="panel-row">
                <RadzenIcon Icon="show_chart" Style="color: var(--color-gray);" />
                <span class="panel-label">Zasil. wg krzywej</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="timer" Style="color: var(--color-cyan);" />
                <span class="panel-label">Offset</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="calculate" Style="color: var(--color-blue);" />
                <span class="panel-label">Zasil. z offsetem</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="tune" Style="color: var(--color-orange);" />
                <span class="panel-label">Zasil. zadane</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="opacity" Style="color: var(--color-red);" />
                <span class="panel-label">Zasil. faktyczne</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="water_drop" Style="color: var(--color-gray);" />
                <span class="panel-label">Powrót fakt.</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
        </div>

        <div class="panel-section">
            <div class="section-title">CWU</div>
            <div class="panel-row">
                <RadzenIcon Icon="bathtub" Style="color: var(--color-orange);" />
                <span class="panel-label">Zadana</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="hot_tub" Style="color: var(--color-red);" />
                <span class="panel-label">Aktualna</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="swap_vert" Style="color: var(--color-cyan);" />
                <span class="panel-label">Delta wygrz.</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="wb_sunny" Style="color: var(--color-green);" />
                <span class="panel-label">Suger. godz. wygrz.</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
        </div>

        <div class="panel-section">
            <div class="section-title">Sprężarka</div>
            <div class="panel-row">
                <RadzenIcon Icon="speed" Style="color: var(--color-blue);" />
                <span class="panel-label">Częstotliwość</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="replay" Style="color: var(--color-orange);" />
                <span class="panel-label">Cykle wł./wył.</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
            <div class="panel-row">
                <RadzenIcon Icon="access_time" Style="color: var(--color-cyan);" />
                <span class="panel-label">Czas pracy</span>
                <span class="panel-value">-- (Faza 1)</span>
            </div>
        </div>
    </div>
</div>

@code {
    private static readonly Temperature TargetTemperature = Temperature.FromCelsius(22.0m);
    private static readonly TimeSpan TimeRange = TimeSpan.FromHours(24);

    private static readonly string[] SensorColors = ["#2196f3", "#26c6da", "#4caf50", "#ff9800"];

    private List<GetAllSensorsHistory.SensorData> _sensorData = [];
    private List<GetWeatherForecast.ForecastPoint> _forecastPoints = [];
    private bool _hasOutdoorData;
    private bool _hasHeatingData = false;
    private bool _hasIndoorData;

    private string? _indoorChartId;
    private string? _outdoorChartId;
    private string? _forecastSeriesId;
    private readonly Dictionary<string, string> _sensorSeriesIds = new();

    private HubConnection? _hubConnection;
    private bool _chartsNeedInit;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
        await LoadForecastAsync();
        _chartsNeedInit = true;
        await InitializeSignalRAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartsNeedInit)
        {
            _chartsNeedInit = false;
            if (_hasIndoorData && _indoorChartId == null)
                await InitializeIndoorChartAsync();
            if (_hasOutdoorData && _outdoorChartId == null)
                await InitializeOutdoorChartAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            var now = DateTimeOffset.UtcNow;
            var query = new GetAllSensorsHistory.Query(now - TimeRange, now);

            var result = await SensorHistoryHandler.HandleAsync(query);
            _sensorData = result.Sensors.ToList();
            _hasIndoorData = _sensorData.Any(s => s.Readings.Count > 0);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load sensor data");
        }
    }

    private async Task LoadForecastAsync()
    {
        try
        {
            var nextFullHour = NextFullHour(DateTimeOffset.UtcNow);
            var query = new GetWeatherForecast.Query(nextFullHour, 25); // 24h + 1 for edge
            var result = await WeatherForecastHandler.HandleAsync(query);
            _forecastPoints = result.Points.ToList();
            _hasOutdoorData = _forecastPoints.Count > 0;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load weather forecast");
        }
    }

    private async Task InitializeIndoorChartAsync()
    {
        if (!_hasIndoorData) return;

        _indoorChartId = await ChartService.InitializeChartAsync("chart-indoor");
        if (_indoorChartId == null) return;

        var colorIndex = 0;
        foreach (var sensor in _sensorData.Where(s => s.Readings.Count > 0))
        {
            var color = SensorColors[colorIndex % SensorColors.Length];
            var seriesId = await ChartService.AddLineSeriesAsync(
                _indoorChartId,
                new LineSeriesOptions(color, 2, sensor.DisplayName, PriceRangeMin: 18m, PriceRangeMax: 25m));

            if (seriesId != null)
            {
                _sensorSeriesIds[sensor.SensorId.Value] = seriesId;

                var dataPoints = sensor.Readings
                    .Select(r => new ChartDataPoint(r.Timestamp.ToUnixTimeSeconds(), r.Temperature.Celsius))
                    .ToList();

                await ChartService.SetDataAsync(seriesId, dataPoints);
            }

            colorIndex++;
        }

        var firstSeries = _sensorSeriesIds.Values.FirstOrDefault();
        if (firstSeries != null)
        {
            await ChartService.AddPriceLineAsync(firstSeries, new PriceLineOptions(
                TargetTemperature.Celsius,
                "#4caf50",
                2,
                2,
                true,
                "Cel"));
        }

        await ChartService.FitContentAsync(_indoorChartId);
    }

    private async Task InitializeOutdoorChartAsync()
    {
        if (!_hasOutdoorData) return;

        _outdoorChartId = await ChartService.InitializeChartAsync("chart-outdoor");
        if (_outdoorChartId == null) return;

        // Dashed line for forecast (LineStyle 2 = Dashed)
        _forecastSeriesId = await ChartService.AddLineSeriesAsync(
            _outdoorChartId,
            new LineSeriesOptions("#ff9800", 2, "Prognoza", LineStyle: 2, PriceRangeMin: -20m, PriceRangeMax: 20m));

        if (_forecastSeriesId != null)
        {
            var dataPoints = _forecastPoints
                .Select(p => new ChartDataPoint(p.Timestamp.ToUnixTimeSeconds(), p.TemperatureCelsius))
                .ToList();

            await ChartService.SetDataAsync(_forecastSeriesId, dataPoints);
        }

        await ChartService.FitContentAsync(_outdoorChartId);
    }

    private async Task InitializeSignalRAsync()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/sensors"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.Closed += OnConnectionClosed;
            _hubConnection.Reconnecting += OnReconnecting;
            _hubConnection.Reconnected += OnReconnected;
            _hubConnection.On<string, decimal, long>("ReceiveSensorUpdate", OnSensorUpdate);
            _hubConnection.On("ReceiveWeatherForecastUpdate", OnWeatherForecastUpdate);

            await _hubConnection.StartAsync();
            Logger.LogInformation("SignalR connection established");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to initialize SignalR connection");
        }
    }

    private Task OnConnectionClosed(Exception? error)
    {
        if (error != null)
        {
            Logger.LogWarning(error, "SignalR connection closed with error");
        }
        else
        {
            Logger.LogInformation("SignalR connection closed");
        }
        return Task.CompletedTask;
    }

    private Task OnReconnecting(Exception? error)
    {
        Logger.LogInformation("SignalR reconnecting...");
        return Task.CompletedTask;
    }

    private Task OnReconnected(string? connectionId)
    {
        Logger.LogInformation("SignalR reconnected: {ConnectionId}", connectionId);
        return Task.CompletedTask;
    }

    private async Task OnSensorUpdate(string sensorId, decimal temperature, long timestamp)
    {
        if (_sensorSeriesIds.TryGetValue(sensorId, out var seriesId))
        {
            await ChartService.UpdateDataAsync(seriesId, new ChartDataPoint(timestamp, temperature));
        }

        var sensor = _sensorData.FirstOrDefault(s => s.SensorId.Value == sensorId);
        if (sensor != null)
        {
            var newReading = new GetAllSensorsHistory.DataPoint(
                Temperature.FromCelsius(temperature),
                DateTimeOffset.FromUnixTimeSeconds(timestamp));

            var readings = sensor.Readings.ToList();
            readings.Add(newReading);

            var index = _sensorData.IndexOf(sensor);
            _sensorData[index] = sensor with { Readings = readings };
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnWeatherForecastUpdate()
    {
        await InvokeAsync(async () =>
        {
            await LoadForecastAsync();

            if (_outdoorChartId != null)
            {
                await ChartService.DestroyChartAsync(_outdoorChartId);
                _outdoorChartId = null;
                _forecastSeriesId = null;
            }

            if (_hasOutdoorData)
            {
                await InitializeOutdoorChartAsync();
            }

            StateHasChanged();
        });
    }

    private static string FormatLatestTemperature(GetAllSensorsHistory.SensorData sensor)
    {
        var latest = sensor.Readings.MaxBy(r => r.Timestamp);
        return latest?.Temperature.ToString() ?? "--";
    }

    private string FormatForecastTemp(int hoursAhead)
    {
        var target = NextFullHour(DateTimeOffset.UtcNow).AddHours(hoursAhead);
        var closest = _forecastPoints.MinBy(p => Math.Abs((p.Timestamp - target).TotalMinutes));
        return closest != null ? $"{closest.TemperatureCelsius:F1}\u00B0C" : "--";
    }

    private static DateTimeOffset NextFullHour(DateTimeOffset now)
    {
        var truncated = new DateTimeOffset(now.Year, now.Month, now.Day, now.Hour, 0, 0, now.Offset);
        return truncated.AddHours(1);
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }

        try
        {
            if (_indoorChartId != null)
            {
                await ChartService.DestroyChartAsync(_indoorChartId);
            }

            if (_outdoorChartId != null)
            {
                await ChartService.DestroyChartAsync(_outdoorChartId);
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit already disconnected, charts will be cleaned up by browser
        }
    }
}
