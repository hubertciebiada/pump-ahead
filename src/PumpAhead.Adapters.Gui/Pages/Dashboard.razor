@page "/"
@implements IAsyncDisposable
@inject IQueryHandler<GetAllSensorsHistory.Query, GetAllSensorsHistory.Data> SensorHistoryHandler
@inject IQueryHandler<GetTemperature.Query, GetTemperature.Data?> TemperatureHandler
@inject LightweightChartsService ChartService
@inject ChartStateService ChartState
@inject NavigationManager NavigationManager
@inject ILogger<Dashboard> Logger

<PageTitle>Dashboard - PumpAhead</PageTitle>

<div class="time-range-selector">
    @foreach (var range in ChartStateService.AvailableRanges)
    {
        <RadzenButton
            Text="@ChartStateService.FormatRange(range)"
            ButtonStyle="@(ChartState.TimeRange == range ? ButtonStyle.Primary : ButtonStyle.Light)"
            Size="ButtonSize.Small"
            Click="@(() => OnTimeRangeChange(range))" />
    }
</div>

<div class="charts-row">
    <div class="chart-container">
        <div class="chart-title">Temperatura zewnętrzna</div>
        <div id="chart-outdoor" class="chart-wrapper">
            @if (!_hasOutdoorData)
            {
                <div class="no-data-message">Brak danych (Heishamon - Faza 1)</div>
            }
        </div>
    </div>

    <div class="chart-container">
        <div class="chart-title">Centralne Ogrzewanie</div>
        <div id="chart-heating" class="chart-wrapper">
            @if (!_hasHeatingData)
            {
                <div class="no-data-message">Brak danych (Heishamon - Faza 1)</div>
            }
        </div>
    </div>

    <div class="chart-container">
        <div class="chart-title">Temperatura wewnętrzna</div>
        <div id="chart-indoor" class="chart-wrapper">
            @if (!_hasIndoorData)
            {
                <div class="no-data-message">Brak danych z sensorów</div>
            }
        </div>
    </div>
</div>

<div class="cards-row">
    <div class="data-card">
        <div class="data-card-title">Otoczenie</div>
        @foreach (var sensor in _sensorData)
        {
            <div class="data-card-row">
                <div class="data-card-icon">
                    <RadzenIcon Icon="home" Style="color: var(--color-blue);" />
                </div>
                <div class="data-card-label">@sensor.DisplayName</div>
                <div class="data-card-value">@FormatLatestTemperature(sensor)</div>
            </div>
        }
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="thermostat" Style="color: var(--color-green);" />
            </div>
            <div class="data-card-label">Wewnętrzna (oczekiwana)</div>
            <div class="data-card-value">@TargetTemperature.ToString()</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="cloud" Style="color: var(--color-cyan);" />
            </div>
            <div class="data-card-label">Zewnętrzna (aktualna)</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="schedule" Style="color: var(--color-orange);" />
            </div>
            <div class="data-card-label">Zewnętrzna (+6h)</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="trending_up" Style="color: var(--color-gray);" />
            </div>
            <div class="data-card-label">Korekta empiryczna</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
    </div>

    <div class="data-card">
        <div class="data-card-title">CO (Centralne Ogrzewanie)</div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="show_chart" Style="color: var(--color-gray);" />
            </div>
            <div class="data-card-label">Zasilanie wg krzywej</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="timer" Style="color: var(--color-cyan);" />
            </div>
            <div class="data-card-label">Offset</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="calculate" Style="color: var(--color-blue);" />
            </div>
            <div class="data-card-label">Zasilanie z offsetem</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="tune" Style="color: var(--color-orange);" />
            </div>
            <div class="data-card-label">Zasilanie zadane</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="opacity" Style="color: var(--color-red);" />
            </div>
            <div class="data-card-label">Zasilanie faktyczne</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="water_drop" Style="color: var(--color-gray);" />
            </div>
            <div class="data-card-label">Powrót faktyczny</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
    </div>

    <div class="data-card">
        <div class="data-card-title">CWU (Ciepła Woda Użytkowa)</div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="bathtub" Style="color: var(--color-orange);" />
            </div>
            <div class="data-card-label">Zadana</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
                <RadzenIcon Icon="hot_tub" Style="color: var(--color-red);" />
            </div>
            <div class="data-card-label">Aktualna</div>
            <div class="data-card-value">-- (Faza 1)</div>
        </div>
        <div class="data-card-row">
            <div class="data-card-icon">
